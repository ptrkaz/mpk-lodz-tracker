{
  "expo": {
    "name": "MPK Łódź Tracker",
    "slug": "mpk-lodz-tracker",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "mpklodz",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "bundleIdentifier": "com.piotr.mpklodz",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Pokażemy pojazdy MPK najbliżej Ciebie."
      }
    },
    "android": {
      "package": "com.piotr.mpklodz",
      "adaptiveIcon": { "backgroundColor": "#ffffff" }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Pokażemy pojazdy MPK najbliżej Ciebie."
        }
      ],
      "expo-dev-client",
      "@maplibre/maplibre-react-native"
    ],
    "extra": {
      "maptilerKey": "${EXPO_PUBLIC_MAPTILER_KEY}"
    }
  }
}
